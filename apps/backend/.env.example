# Database
DATABASE_URL="postgresql://campusphere:campusphere_dev_password@localhost:5432/campusphere?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Authentication
JWT_SECRET="campusphere-dev-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="campusphere-dev-refresh-secret-change-in-production"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=4000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://localhost:3002"

# Cloudinary (optional — for image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SMTP (optional — for email notifications)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Razorpay (optional — for online payments)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
